# iMessage Agent Configuration
# Copy this file to config.env and fill in your values.

# Your phone number in E.164 format (the number you'll send instructions FROM)
AUTHORIZED_HANDLE="+1XXXXXXXXXX"

# Your iMessage account ID (found via: osascript -e 'tell application "Messages" to get id of every account')
# Use the account ID associated with the iMessage service on this Mac.
IMESSAGE_ACCOUNT="XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"

# Poll interval in seconds (how often to check for new messages)
POLL_INTERVAL=5
