# iMessage Agent Configuration
# Copy this file to config.env and fill in your values.

# Your phone number in E.164 format (the number you'll send instructions FROM)
AUTHORIZED_HANDLE="+1XXXXXXXXXX"

# Your iMessage account ID (found via: osascript -e 'tell application "Messages" to get id of every account')
# Use the account ID associated with the iMessage service on this Mac.
IMESSAGE_ACCOUNT="XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"

# Poll interval in seconds (how often to check for new messages)
POLL_INTERVAL=5

# Project directory for Claude Code (contains CLAUDE.md and .claude/settings.json)
# This directory defines what tools/MCP servers Claude has access to.
# Default: ~/home-agent
# HOME_AGENT_DIR="$HOME/home-agent"

# Execution timeout in seconds (default: 300 = 5 minutes)
# Instructions that exceed this are killed and you get a timeout message.
# EXEC_TIMEOUT=300

# Claude model to use (default: claude-sonnet-4-6)
# Sonnet is fast and handles most tasks well. Use opus for complex reasoning.
# CLAUDE_MODEL="claude-sonnet-4-6"
